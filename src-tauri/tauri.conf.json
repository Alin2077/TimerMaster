{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/v2/crates/tauri-utils/schema.json",
  "productName": "TimerMaster",
  "version": "3.0.0",
  "identifier": "com.timermaster.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TimerMaster - \u5b9a\u65f6\u52a9\u624b",
        "width": 480,
        "height": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://cdn.jsdelivr.net/gh/Alin2077/TimerMaster@master/updater.json",
        "https://github.com/Alin2077/TimerMaster/releases/latest/download/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFGNDQ0NUJCQjM5MzgyQjAKUldTd2dwT3p1MFZFcnc3RTVEWXB4bE9WM2tyditUeUwrbUkrTXlXY3doYUxubGMxaVRLQWd0NTUK"
    }
  }
}